# ReadRight — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in real values (get them from @infra-dev who completed RR-001)
#   3. NEVER commit .env.local — it is already in .gitignore
#
# All vars must be prefixed VITE_ to be exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — from RR-001 (Project Settings → API → Publishable key)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# FastAPI AI Microservice — from RR-005 (fill in when deployed)
VITE_FASTAPI_URL=
VITE_API_KEY=
